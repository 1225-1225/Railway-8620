# .env
COMPOSE_PROJECT_NAME=railway-8620
chat_model_name=deepseek-v4-flash
collection_name=railway-8620
kwargs=5
chunk_size=500
chunk_overlap=77
history_database_name=chat_history_check_pointer

OPENCODE_GO_API_KEY=""
DASHSCOPE_API_KEY=""

# LLM 供应商：openai / anthropic
llm_provider=openai
# llm_api_key=""
llm_model_name=deepseek-v4-flash
# 使用兼容 OpenAI 格式的第三方 API 时，加这个
llm_base_url=https://opencode.ai/zen/go/v1

# Embedding（阿里百炼，兼容 OpenAI 格式）
embedding_provider=openai
embedding_model_name=text-embedding-v4
embedding_base_url=https://dashscope.aliyuncs.com/compatible-mode/v1