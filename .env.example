# .env.example —— 复制为 .env 并填入你的真实 API Key
#
# 两种写法都支持：
#   llm_api_key=sk-xxx              → 直接用
#   llm_api_key=OPENCODE_GO_API_KEY → 视为环境变量名，取 os.environ["OPENCODE_GO_API_KEY"]
#   后者可让 .env 进 Git，真实 key 放在 CI/CD 系统环境变量中
COMPOSE_PROJECT_NAME=railway-8620
collection_name=railway-8620
kwargs=5
chunk_size=500
chunk_overlap=77
history_database_name=chat_history_check_pointer

# LLM API Key（必填）
llm_api_key="your-api-key-here"
# Embedding API Key（必填，阿里百炼等 OpenAI 兼容服务）
embedding_api_key="your-api-key-here"

# JWT 签名密钥（必填，生产环境务必更换为高熵随机串，未配置时签发/校验会直接抛错）
JWT_SECRET_KEY="your-secret-key-change-in-production"

# 用户库 SQLite 路径，默认相对当前工作目录；生产建议填绝对路径
DATABASE_URL="sqlite:///./users.db"

# CORS 允许来源，逗号分隔；前端走 Nginx 反代时同源无需配置
CORS_ORIGINS="http://localhost:8620"

# LLM 供应商：openai / anthropic
llm_provider=openai
llm_model_name=deepseek-v4-flash
llm_base_url=https://opencode.ai/zen/go/v1

# Embedding（阿里百炼，兼容 OpenAI 格式）
embedding_provider=openai
embedding_model_name=text-embedding-v4
embedding_base_url=https://dashscope.aliyuncs.com/compatible-mode/v1
